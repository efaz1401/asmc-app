# Database — Postgres only. Spin up a local container with
#   docker compose up -d db
# from the repo root, then leave this URL as-is for dev.
DATABASE_URL="postgresql://asmc:password@localhost:5432/asmc?schema=public"

# JWT — use long random strings in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN="*"

# Set to "true" on the first deploy to populate seed users, then back to "false".
SEED_ON_BOOT="false"

# Optional integrations (placeholders — fill in when you wire them up)
FCM_SERVER_KEY=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
S3_BUCKET=""
S3_REGION=""
