# Database — defaults to local SQLite for dev.
# For Postgres in production, switch the provider in prisma/schema.prisma to
# "postgresql" and set DATABASE_URL to your Postgres connection string, e.g.:
#   DATABASE_URL="postgresql://user:password@localhost:5432/asmc?schema=public"
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN="*"

# Optional integrations (placeholders — fill in when you wire them up)
FCM_SERVER_KEY=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
S3_BUCKET=""
S3_REGION=""
