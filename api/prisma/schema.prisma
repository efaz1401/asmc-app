// ASMC Workforce Management — Prisma schema
//
// PostgreSQL is the only supported provider. For local dev, run a Postgres
// container with `docker compose up -d db` (see `docker-compose.yml`) and
// point DATABASE_URL at it. In production set DATABASE_URL to the managed
// Postgres connection string (Render attaches one automatically).

generator client {
  provider      = "prisma-client-js"
  // Native target covers local dev; linux-musl-openssl-3.0.x is needed for
  // node:20-alpine on Render (alpine 3.18+ ships OpenSSL 3.x).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (modelled as string constants for SQLite compatibility) ────────────
// Allowed values for User.role:
//   SUPER_ADMIN | HR_ADMIN | SUPERVISOR | CLIENT | EMPLOYEE
// Allowed values for Employee.availability:
//   AVAILABLE | DEPLOYED | ON_LEAVE | INACTIVE
// Allowed values for Deployment.status:
//   SCHEDULED | ACTIVE | COMPLETED | CANCELLED
// Allowed values for Attendance.status:
//   PRESENT | ABSENT | LATE | HALF_DAY | LEAVE
// Allowed values for Invoice.status:
//   DRAFT | SENT | PAID | OVERDUE | CANCELLED
// Allowed values for Notification.type:
//   ATTENDANCE | PAYROLL | DEPLOYMENT | CONTRACT | GENERAL

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  fullName     String
  role         String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 1:1 links to a profile (employee or client) when applicable
  employee Employee?
  client   Client?

  refreshTokens RefreshToken[]
  otps          OtpCode[]
  notifications Notification[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String
  code      String
  purpose   String   // RESET_PASSWORD | VERIFY_EMAIL | LOGIN_2FA
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Employee {
  id               String   @id @default(uuid())
  userId           String   @unique
  employeeCode     String   @unique
  fullName         String
  profilePhotoUrl  String?
  phone            String?
  email            String?
  address          String?
  nationalId       String?
  emergencyContact String?
  department       String?
  trade            String?
  skillCategory    String?
  salary           Float    @default(0)
  joiningDate      DateTime?
  availability     String   @default("AVAILABLE")
  isActive         Boolean  @default(true)
  visaNumber       String?
  visaExpiry       DateTime?
  workPermitNumber String?
  workPermitExpiry DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployments Deployment[]
  attendance  Attendance[]
  payroll     Payroll[]
  documents   Document[]
  contracts   Contract[]
}

model Client {
  id              String   @id @default(uuid())
  userId          String?  @unique
  companyName     String
  contactPerson   String?
  phone           String?
  email           String?
  address         String?
  industry        String?
  billingAddress  String?
  taxId           String?
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  deployments Deployment[]
  invoices    Invoice[]
  contracts   Contract[]
}

model Deployment {
  id           String   @id @default(uuid())
  employeeId   String
  clientId     String
  supervisorId String?
  projectName  String?
  startDate    DateTime
  endDate      DateTime?
  shift        String?  // MORNING | EVENING | NIGHT | FULL_DAY
  status       String   @default("SCHEDULED")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  attendance Attendance[]

  @@index([employeeId, startDate])
  @@index([clientId, startDate])
}

model Attendance {
  id           String   @id @default(uuid())
  employeeId   String
  deploymentId String?
  date         DateTime
  checkInAt    DateTime?
  checkOutAt   DateTime?
  status       String   @default("PRESENT")
  hoursWorked  Float?
  overtimeHours Float?
  location     String?
  approvedById String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  deployment Deployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([date])
}

model Payroll {
  id            String   @id @default(uuid())
  employeeId    String
  periodStart   DateTime
  periodEnd     DateTime
  baseSalary    Float    @default(0)
  overtimePay   Float    @default(0)
  bonus         Float    @default(0)
  deductions    Float    @default(0)
  netAmount     Float    @default(0)
  paid          Boolean  @default(false)
  paidAt        DateTime?
  payslipUrl    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, periodStart])
}

model Invoice {
  id           String   @id @default(uuid())
  invoiceNo    String   @unique
  clientId     String
  issuedAt     DateTime @default(now())
  dueAt        DateTime?
  amount       Float    @default(0)
  tax          Float    @default(0)
  total        Float    @default(0)
  status       String   @default("DRAFT")
  pdfUrl       String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items  InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  total       Float   @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Contract {
  id          String   @id @default(uuid())
  title       String
  type        String   // EMPLOYEE | CLIENT
  employeeId  String?
  clientId    String?
  startDate   DateTime
  endDate     DateTime?
  documentUrl String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model Document {
  id          String   @id @default(uuid())
  employeeId  String?
  name        String
  type        String?
  url         String
  uploadedAt  DateTime @default(now())

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   @default("GENERAL")
  data      String?  // JSON string for extra payload
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
